# ============================================
# OpenWiki + DeepAgents Configuration
# ============================================

# --- LLM Provider (choose one) ---
# Options: openai, anthropic, openrouter
OPENWIKI_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenRouter ---
# OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# --- LangSmith Tracing (Optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=personal-brain-openwiki

# --- Personal Brain Connectors ---
# Gmail OAuth (for email ingestion)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# Notion (for notes ingestion)
# NOTION_API_KEY=

# Tavily (for web search)
# TAVILY_API_KEY=

# X/Twitter OAuth
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_ACCESS_TOKEN=

# --- Wiki Configuration ---
WIKI_OUTPUT_DIR=./wiki-output
WIKI_FOCUS="AI projects, development workflows, and technical research"
