{
  "name": "personal-brain-openwiki",
  "version": "1.0.0",
  "description": "A TypeScript project demonstrating OpenWiki + DeepAgents integration for building AI agents with proactive wiki memory",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "agent:code-reviewer": "tsx src/agents/code-reviewer-agent.ts",
    "agent:wiki-memory": "tsx src/agents/wiki-memory-agent.ts",
    "cli:brain": "tsx src/cli/personal-brain-cli.ts",
    "cli:ingest": "tsx src/cli/ingest-sources.ts",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openwiki",
    "deepagents",
    "langchain",
    "ai-agents",
    "personal-brain",
    "wiki-memory",
    "typescript"
  ],
  "author": "ALaaAlawdi",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.4.0",
    "@langchain/anthropic": "^0.3.0",
    "deepagents": "^0.5.0",
    "langchain": "^0.3.0",
    "zod": "^3.23.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.0",
    "glob": "^10.3.0",
    "dotenv": "^16.4.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
